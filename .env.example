# =============================================================================
# .env.example — documenta TODAS as variaveis. NAO coloque valores reais aqui.
# Copie para .env (fora do versionamento) e preencha. Segredos: §4.1.
# =============================================================================

# ---- Ambiente ----
APP_ENV=development                 # development | production
APP_DEBUG=true
APP_NAME=agenda_de_atendimentos
TZ=America/Sao_Paulo
# Tag local estavel das imagens proprias; o bundle de recovery preserva o conteudo exato.
AGENDA_IMAGE_TAG=current

# ---- Backend / API ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000                   # porta interna do contentor (uvicorn)
# Porta publicada no HOST (so no localhost). Ajuste se houver conflito no servidor.
# ATENCAO: neste servidor a 8000 ja e usada pelo Portainer -> usar outra (ex.: 8010).
BACKEND_HOST_PORT=8000
UVICORN_WORKERS=2                   # AMD A6 = 2 nucleos (§1.3)
# Frontend (SPA + Nginx, Fase 7) — ponto de entrada do browser, so no localhost.
FRONTEND_HOST_PORT=8080

# ---- Seguranca / JWT (§2.1, §4.1) ----
JWT_SECRET_KEY=                     # gerar forte; via Docker Secret em producao
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---- Cookie de sessao da SPA (Fase 7, §2.2/§4.1) ----
COOKIE_NAME=agenda_session
# COOKIE_SECURE exige HTTPS. Em dev/HTTP (ex.: acesso por 127.0.0.1) use false,
# senao o browser NAO envia o cookie e o login "nao gruda". Sob TLS (§9): true.
COOKIE_SECURE=false
COOKIE_SAMESITE=strict

# ---- PostgreSQL (§1.1, §1.2) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=agenda
# Role de bootstrap/migracao criado pela imagem (superusuario, dono das tabelas).
# Usado pelas migrations (Alembic). Ver §2.1.1.
POSTGRES_USER=agenda_admin
POSTGRES_PASSWORD=                  # via Docker Secret em producao

# Role de APLICACAO (NOSUPERUSER, NOBYPASSRLS), sujeito ao RLS (§2.1.1).
# Provisionado no init do cluster (infra/postgres/init/02-roles.sh) na 1a subida.
APP_DB_USER=agenda_app
APP_DB_PASSWORD=                    # gerar no servidor; via Docker Secret em producao
# String de ligacao de runtime do backend (agenda_app). Deve usar APP_DB_PASSWORD.
# Pool dimensionado p/ max_connections=50 (§1.2). Usado a partir da Fase 2.
DATABASE_URL=postgresql+psycopg://agenda_app:CHANGE_ME@postgres:5432/agenda

# ---- Administracao da BD ----
# Sem GUI/console web (decisao de menor exposicao, §2.1.1/§4.1).
# Acesso administrativo: docker compose exec postgres psql -U <role> -d agenda

# ---- OpenAI (§0.2, §4.1) ----
OPENAI_API_KEY=                     # via Docker Secret em producao; sem ela, embeddings ficam pendentes
OPENAI_EMBEDDING_MODEL=text-embedding-3-small   # 1536 dims (§3.1); trocar exige alterar a coluna vector()
OPENAI_TIMEOUT_SECONDS=20           # timeout curto p/ embeddings (sincronos, 2 workers §1.3)
OPENAI_CHAT_MODEL=gpt-4o-mini       # geracao de rascunho (Fase 6, §3.4)
OPENAI_CHAT_TEMPERATURE=0.3         # baixa p/ consistencia clinica
OPENAI_CHAT_TIMEOUT_SECONDS=60      # geracao e mais lenta que embeddings

# ---- Pseudonimizacao / NER (§2.3/§1.3) ----
NER_HABILITADO=true                 # camada NER (Presidio+spaCy) atras do extra [nlp]
NER_MODELO_SPACY=pt_core_news_sm    # modelo pequeno p/ caber no mem_limit 1 GB (§1.1)

# ---- Documentos clinicos privados (Fase 7k) ----
# Volume montado apenas no backend. Limites em bytes; 20 MiB por arquivo e 2 GiB/tenant.
DOCUMENTOS_DIR=/app/data/documentos
DOCUMENTOS_TAMANHO_MAX_BYTES=20971520
DOCUMENTOS_COTA_TENANT_BYTES=2147483648
DOCUMENTOS_SANITIZACAO_TIMEOUT_SECONDS=35

# ---- n8n (webhook autenticado — §4.2) ----
N8N_WEBHOOK_URL=
N8N_WEBHOOK_TOKEN=                  # token compartilhado FastAPI <-> n8n
